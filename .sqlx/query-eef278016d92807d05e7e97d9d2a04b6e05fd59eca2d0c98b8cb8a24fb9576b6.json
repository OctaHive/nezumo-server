  "query": "\n        SELECT id, board_id, token, role, created_by, expires_at, created_at\n        FROM board_invite_links\n        WHERE board_id = $1\n          AND (expires_at IS NULL OR expires_at > NOW())\n        ORDER BY created_at DESC\n        ",
