  "query": "\n        SELECT\n            user_id as \"user_id!\",\n            code,\n            expires_at as \"expires_at!\"\n        FROM users_password_reset_codes\n        WHERE user_id = $1 AND expires_at > $2\n        ORDER BY expires_at DESC\n        LIMIT 1\n        ",
