# ==============================
# ⚙️ GENERAL CONFIGURATION
# ==============================
ENVIRONMENT="development" # "production"

# Runtime defaults. Administrators can override these non-secret values from
# Server Settings; persisted database values take precedence.
PUBLIC_REGISTRATION_ENABLED=true
GOOGLE_LOGIN_ENABLED=true

# ==============================
# 🌍 SERVER CONFIGURATION
# ==============================

# IP address the server will bind to (0.0.0.0 allows all network interfaces)
SERVER_IP="0.0.0.0"

# Port the server will listen on
SERVER_PORT="3000"

# Enable tracing for debugging/logging (true/false)
SERVER_TRACE_ENABLED=true

# Reserved for Compose compatibility. The current server does not read this
# variable and uses Tokio's default worker-thread configuration.
SERVER_WORKER_THREADS=2


# ==============================
# 🔒 HTTPS CONFIGURATION
# ==============================

# Enable HTTPS (true/false)
SERVER_HTTPS_ENABLED=false

# Enable HTTP/2 when using HTTPS (true/false)
SERVER_HTTPS_HTTP2_ENABLED=true

# Path to the SSL certificate file (only used if SERVER_HTTPS_ENABLED=true)
SERVER_HTTPS_CERT_FILE_PATH=cert.pem

# Path to the SSL private key file (only used if SERVER_HTTPS_ENABLED=true)
SERVER_HTTPS_KEY_FILE_PATH=key.pem


# ==============================
# 🚦 RATE LIMIT CONFIGURATION
# ==============================

# Reserved for Compose compatibility. Rate-limit middleware is not currently
# wired to these variables, so changing them has no effect yet.
SERVER_RATE_LIMIT=5

# Intended rate-limit period, in seconds (currently unused; see above)
SERVER_RATE_LIMIT_PERIOD=1


# ==============================
# 📦 COMPRESSION CONFIGURATION
# ==============================

# Enable Brotli compression (true/false)
SERVER_COMPRESSION_ENABLED=true

# Compression level (valid range: 0-11, where 11 is the highest compression)
SERVER_COMPRESSION_LEVEL=6


# ==============================
# 🔑 AUTHENTICATION CONFIGURATION
# ==============================

# JWT secret key.
JWT_SECRET_KEY="Change me!"

# JWT issuer
JWT_ISSUER="your_issuer"  # Set this to your desired issuer value

# JWT audience
JWT_AUDIENCE="your_audience"  # Set this to your desired audience value

# Allow authentication via HTTP cookies (true/false)
JWT_ALLOW_COOKIE_AUTH=true

# Force authentication via HTTP cookies only (true/false)
JWT_FORCE_COOKIE_AUTH=false

# Name of the cookie used to store the JWT token
JWT_COOKIE_NAME="auth_token"

# Maximum age of the JWT token in seconds
JWT_COOKIE_MAX_AGE=604800 # 7 days in seconds

# SameSite attribute for the JWT cookie (Lax, Strict, or None), SERVER_HTTPS_ENABLED must be true.
JWT_COOKIE_SAMESITE="Lax" 


# ==============================
# 🔐 GOOGLE OAUTH CONFIGURATION
# ==============================

# Public origin of the frontend. OAuth redirects are restricted to this origin.
APP_ORIGIN="http://localhost:5173"

# Google OpenID Connect issuer (normally does not need to be changed)
GOOGLE_ISSUER_URL="https://accounts.google.com"

# OAuth credentials and callback registered in Google Cloud Console
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URL="http://localhost:3000/api/v1/oauth/google/callback"

# Optional OAuth client ID used by the desktop application
GOOGLE_DESKTOP_CLIENT_ID=""


# ==============================
# 🌐 CORS CONFIGURATION
# ==============================

# Allowed origin for CORS requests (comma-separated for multiple origins)
# Example: "http://127.0.0.1:3000,http://localhost:3000"
CORS_ALLOW_ORIGIN="*"

# Allowed HTTP methods for CORS (comma-separated)
# Example: "GET,POST,PUT,DELETE,OPTIONS"
CORS_ALLOW_METHODS="GET,POST,PUT,DELETE,OPTIONS,PATCH"

# Allowed headers for CORS (comma-separated)
# Example: "Authorization,Content-Type,Origin"
CORS_ALLOW_HEADERS="Authorization,Content-Type,Origin"

# Allow credentials (true/false)
CORS_ALLOW_CREDENTIALS=true

# Max age (in seconds) for preflight request caching
CORS_MAX_AGE=3600


# ==============================
# 🛢️ DATABASE CONFIGURATION
# ==============================

# For running Nezumo standalone:
DATABASE_URL="postgres://dbuser:1234@localhost/nezumo"

# For docker:
DATABASE_USER=dbuser
DATABASE_PASSWORD=1234
DATABASE_DB=nezumo

# Maximum number of connections in the database pool
DATABASE_MAX_CONNECTIONS=20

# Minimum number of connections in the database pool
DATABASE_MIN_CONNECTIONS=5

# Number of database connection attempts and delay between them
DATABASE_CONNECT_RETRIES=10
DATABASE_CONNECT_RETRY_DELAY_MS=1000

# Timeout for acquiring a connection from the pool
DATABASE_ACQUIRE_TIMEOUT_SECS=15


# ==============================
# ☁️ STORAGE (S3/MINIO) CONFIGURATION
# ==============================

# Endpoint (e.g., http://127.0.0.1)
STORAGE_HOST="http://127.0.0.1"

# Port for the storage service (e.g., 9000 for MinIO)
STORAGE_PORT="9000"

# Port for the management console (e.g., 9001 for MinIO)`, not used by Nezumo, used to configure Docker.
STORAGE_CONSOLE_PORT="9001"

# Region (e.g., us-east-1)
STORAGE_REGION="us-east-1"

# Access key
STORAGE_ACCESS_KEY="minioadmin"

# Secret key
STORAGE_SECRET_KEY="minioadmin"

# Browser-accessible S3 endpoint used only in generated presigned URLs.
# Leave empty when STORAGE_HOST is already reachable from the browser.
STORAGE_PUBLIC_ENDPOINT=""

# Storage startup connection attempts and delay between them
STORAGE_CONNECT_RETRIES=10
STORAGE_CONNECT_RETRY_DELAY_MS=1000

# Lifetime of generated board-file URLs, in seconds
STORAGE_PRESIGN_TTL_SECONDS=3600

# Bucket name for storing profile pictures.
# In production, make sure that this bucket has been created beforehand.
STORAGE_BUCKET_PROFILE_PICTURES="profile_pictures"

# Bucket name for storing board files (images, attachments, etc.).
# In production, make sure that this bucket has been created beforehand.
STORAGE_BUCKET_BOARD_FILES="board-files"


# ==============================
# 🟢 SUPPORT / "REPORT A PROBLEM"
# ==============================
# POST /api/v1/support/reports opens a GitHub issue from the in-app
# "report a problem" dialog. Leave the token empty to disable (the endpoint
# returns 503). The token is server-side only and never reaches the client.
# Target repository as "owner/repo" (may be private).
GITHUB_ISSUES_REPO=""
# Token with "Issues: write" on that repo (fine-grained PAT, or classic PAT
# with the `repo` scope for a private repository).
GITHUB_ISSUES_TOKEN=""
# Comma-separated labels applied to created issues (default: support).
GITHUB_ISSUES_LABELS="support"
# Max successful reports per user per day (default 10; 0 = unlimited). Tracked
# in Redis; fails open if Redis is unavailable.
SUPPORT_MAX_REPORTS_PER_DAY="10"

# Feature-request reports use the same GitHub repository and token.
GITHUB_FEATURE_REQUEST_LABELS="feature request"
FEATURE_REQUEST_MAX_PER_DAY="5"

# Return the created GitHub issue URL to the feature-request client.
FEATURE_REQUEST_EXPOSE_ISSUE_URL=false
# S3 bucket for "report a problem" attachments. If empty, falls back to
# STORAGE_BUCKET_BOARD_FILES. Create this bucket beforehand in production.
STORAGE_BUCKET_SUPPORT="support-files"
# If the support bucket uses SEPARATE credentials (different access key, or even
# a different host/provider), set these. When the access/secret keys are empty,
# the support bucket reuses the main STORAGE_* client. HOST/PORT/REGION fall back
# to the main STORAGE_* values when omitted (use them only for a different host).
STORAGE_SUPPORT_ACCESS_KEY=""
STORAGE_SUPPORT_SECRET_KEY=""
STORAGE_SUPPORT_HOST=""
STORAGE_SUPPORT_PORT=""
STORAGE_SUPPORT_REGION=""
# Public origin of the app/API (no trailing slash), used to build absolute
# attachment URLs in the issue (served by GET /api/v1/support/attachments/...,
# access-controlled by a signed token bound to the file). Falls back to the
# request Origin header if unset, but set it explicitly in production.
PUBLIC_BASE_URL="https://app.nezumo.ru"


# ==============================
# 🟢 BOARD PREVIEWS (THUMBNAILS)
# ==============================
# Server-side board previews are rendered by the standalone `nezumo-render`
# binary (native wgpu offscreen renderer) and stored in STORAGE_BUCKET_BOARD_FILES
# at key boards/{id}/preview.png. A dedicated preview job refreshes changed boards.

# Path or name (on PATH) of a separately distributed renderer binary compatible
# with the backend's Yrs wire protocol. This repository does not contain its
# sources or build instructions. The host needs a GPU or a software Vulkan/GL
# stack such as Mesa lavapipe. If the executable is missing, canonical board
# writes, previews, and exports fail when they first need a renderer worker.
PREVIEW_RENDERER_BIN="nezumo-render"

# Writable persistent directory for assets fetched while rendering previews and
# SVG exports. Validator workers do not use this cache. With a hardened systemd
# unit, create the directory through CacheDirectory=nezumo-render and set the
# value below to /var/cache/nezumo-render.
NEZUMO_ASSET_CACHE_DIR=""

# Number of isolated renderer processes used to validate canonical Yrs updates.
YRS_VALIDATOR_WORKERS=2

# Maximum duration of one validation request before its worker is restarted.
YRS_VALIDATOR_TIMEOUT_MS=5000

# Base URL the renderer fetches relative board assets (fonts, images) from —
# typically the SPA origin that serves /assets/... (e.g. https://app.nezumo.ru).
# PDF page SVGs are presigned directly before preview/export and do not depend
# on this value. Leave empty only when the remaining relative assets are unused.
ASSET_BASE_URL=""

# Local directory of font files — used by BOTH:
#  • SVG export @font-face embedding (`nezumo-render --svg`). Optional there:
#    empty ⇒ the SVG fetches subset-woff2 over HTTP from ASSET_BASE_URL instead.
#  • PDF export (GET .../export/image?format=pdf). The SVG→PDF converter (usvg)
#    can't decode the SVG's embedded subset-woff2, so it shapes text from real
#    OTF/TTF font files in this dir — otherwise PDF text falls back to a serif.
# Holds fonts.json + {variant}.woff2/.ttf/.otf (e.g. the deployed
# apps/app/public/assets/fonts, or the complete `backend/fonts` set shipped with
# the server). If empty, PDF export uses `./fonts` next to the binary (the shipped
# complete set), so for PDF you can either leave this empty and place `fonts/` next
# to the binary, or set it to a dir holding the full OTF/TTF set.
RENDER_FONTS_DIR=""

# Longest side of the generated preview image, in pixels.
PREVIEW_MAX_PX="512"

# How often to scan for stale board thumbnails and how many to refresh per scan.
PREVIEW_JOB_INTERVAL_SECS="60"
PREVIEW_JOB_BATCH_LIMIT="10"

# Minimum seconds between successful thumbnail renders for the same board.
PREVIEW_INTERVAL_SECS="3600"

# Maximum time allowed for one raster, SVG, or PDF export render.
EXPORT_RENDER_TIMEOUT_SECS="300"

# Raster-export resolution used when the request does not specify max_px.
# 4K is safe on software Vulkan (llvmpipe); clients may explicitly request up
# to the hard 16384-pixel ceiling on faster hardware.
EXPORT_DEFAULT_MAX_PX="4096"

# Path or executable name for MuPDF, used when converting uploaded PDFs.
MUTOOL_BIN="mutool"


# ==============================
# 🟣 REALTIME CONFIGURATION
# ==============================

# Persist event commits with PostgreSQL synchronous_commit disabled.
# Faster, but recently acknowledged events may be lost after a database crash.
REALTIME_ASYNC_COMMIT=false

# Aggregate cursor updates into shared frames. Disable only as a compatibility
# fallback for clients that cannot consume the aggregated cursor message.
REALTIME_CURSOR_AGGREGATION=true
REALTIME_CURSOR_MAX_PER_FRAME=60

# Broadcast ring sizes and maximum commits drained into one outgoing batch.
REALTIME_BROADCAST_CAPACITY=4096
REALTIME_PREVIEW_CAPACITY=2048
REALTIME_MAX_BATCH_DRAIN=4096

# Per-WebSocket buffer for acknowledgements sent to the originating client.
REALTIME_CONN_SEND_BUFFER=1024

# Use a distinct presence entry for each connected session.
REALTIME_PRESENCE_PER_SESSION_ENABLED=false

# Canonical Yrs journal and covered board-event retention. Disabled by default;
# enable only after immutable checkpoint creation is operating normally.
YRS_JOURNAL_GC_ENABLED=false
YRS_JOURNAL_RETENTION_DAYS=30
YRS_JOURNAL_GC_INTERVAL_SECS=900
YRS_JOURNAL_GC_BATCH_LIMIT=1000

# Destructive asset deletion remains independently fail-closed.
YRS_ASSET_GC_DELETE_ENABLED=false

# Redis wake-up fan-out identity and reconciliation interval. The identity is
# optional (a random process id is generated); when set it must be unique.
YRS_FANOUT_INSTANCE_ID=""
YRS_FANOUT_REPAIR_MS=1000


# ==============================
# 🖼️ IMAGE PROCESSING
# ==============================

# Print timing information for profile-picture processing.
IMAGE_DEBUG=false


# ==============================
# 🟢 REDIS CONFIGURATION
# ==============================

# Redis hostname or IP (no protocol)
CACHE_ENDPOINT="127.0.0.1"

# Redis port (default: 6379)
CACHE_PORT="6379"

# Redis username (optional, only needed if your Redis server requires it)
CACHE_USERNAME=""

# Redis password (optional, set if your Redis server requires authentication)
CACHE_PASSWORD=""

# Redis database number (default: 0)
CACHE_DB="0"


# ==============================
# 📧 MAIL (SMTP) CONFIGURATION
# ==============================

# SMTP server hostname or IP (e.g., smtp.gmail.com)
MAIL_SERVER="smtp.example.com"

# SMTP port (usually 587 for STARTTLS, 465 for SSL/TLS)
MAIL_PORT="587"

# SMTP username (your email address or login)
MAIL_USER="your@email.com"

# SMTP password
MAIL_PASS="your_smtp_password"

# Sender address. Required even when SMTP authentication is disabled.
MAIL_FROM="no-reply@example.com"

# SMTP transport mode: none, starttls, or implicit
MAIL_SECURITY="starttls"

# Directory containing footer.html and other mail templates
MAIL_TEMPLATES_DIR="templates/mail"


# ==============================
# ⏱️ BACKGROUND JOBS AND LOGGING
# ==============================

# tracing-subscriber filter, for example: info,nezumo=debug,tower_http=debug
RUST_LOG="info"
## Permanent canonical Yrs checkpointing.
YRS_COMPACTION_INTERVAL_SECS=300
YRS_COMPACTION_BATCH_LIMIT=10
YRS_COMPACTION_MIN_UPDATES=512
YRS_COMPACTION_MIN_BYTES=8388608
